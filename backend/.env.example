APP_NAME="Smart Fleet API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_fleet
DB_USERNAME=root
DB_PASSWORD=

FRONTEND_URL=http://localhost:4200

ML_API_URL=

COMPANY_NUMBER=33439711

# false = Mailtrap sandbox (emails capturés sur mailtrap.io, pas dans Gmail)
# true  = SMTP "réel" (remplir MAIL_REAL_* — ex. Gmail + mot de passe d'application)
MAIL_USE_REAL_INBOX=false

# SMTP / Email (Mailtrap or Gmail SMTP)
# Mailtrap (recommended for development):
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@smartfleet.local
MAIL_FROM_NAME="Smart Fleet"

# Livraison réelle (utilisé uniquement si MAIL_USE_REAL_INBOX=true)
MAIL_REAL_HOST=smtp.gmail.com
MAIL_REAL_PORT=587
MAIL_REAL_USERNAME=
MAIL_REAL_PASSWORD=
MAIL_REAL_ENCRYPTION=tls
MAIL_REAL_FROM_ADDRESS=

# Pour Gmail réel : MAIL_USE_REAL_INBOX=true puis remplir MAIL_REAL_* (mot de passe d'application Google).

# OSRM routing (optional; public demo server if unset). Same backend as Leaflet Routing Machine.
# OSRM_BASE_URL=https://router.project-osrm.org

# Realtime notifications (Pusher-compatible)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
